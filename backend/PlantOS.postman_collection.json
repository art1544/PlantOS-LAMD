{
	"info": {
		"_postman_id": "plantos-collection-2026",
		"name": "PlantOS — Ordens de Serviço (Sprint 2)",
		"description": "Coleção de testes para a API REST do PlantOS após Sprint 2.\n\n**Inclui:**\n* Autenticação JWT (`/auth/register`, `/auth/login`, `/auth/me`)\n* RBAC: operador, técnico, admin\n* Ordens de Serviço (CRUD + transições) — todas autenticadas\n* Materiais\n* Fluxo completo Sprint 2 (criar operador + técnico, login, criar OS, aceitar, iniciar, registrar material, concluir)\n\n**Pré-condição:** rodar `python app.py` no diretório `backend/`. Para evidência de eventos, ter o RabbitMQ rodando (`infra/docker-compose.yml`) e o worker (`python worker.py`) em paralelo.\n\nDisciplina: Lab. de Desenvolvimento de Aplicações Móveis e Distribuídas — PUC Minas",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "base_url",  "value": "http://localhost:5000", "type": "string" },
		{ "key": "op_token",  "value": "", "type": "string" },
		{ "key": "tec_token", "value": "", "type": "string" },
		{ "key": "os_id",     "value": "1", "type": "string" }
	],
	"item": [
		{
			"name": "Auth",
			"description": "Endpoints de autenticação JWT. Os scripts de teste salvam automaticamente o token na variável da coleção.",
			"item": [
				{
					"name": "Registrar Operador",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"pm.test('Status 201 ou 409', () => pm.expect([201,409]).to.include(pm.response.code));"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Carla Operadora\",\n  \"login\": \"op-carla\",\n  \"senha\": \"senha123\",\n  \"role\": \"operador\"\n}" },
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] },
						"description": "Cadastra um novo usuário com role `operador`."
					},
					"response": [
						{
							"name": "201 — Operador criado",
							"originalRequest": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": {"mode":"raw","raw":"{\"login\":\"op-carla\",\"senha\":\"senha123\",\"role\":\"operador\",\"nome\":\"Carla\"}"}, "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] } },
							"status": "CREATED",
							"code": 201,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"id\": 1,\n  \"nome\": \"Carla Operadora\",\n  \"login\": \"op-carla\",\n  \"role\": \"operador\",\n  \"ativo\": 1,\n  \"criado_em\": \"2026-05-25T14:00:00.000000Z\",\n  \"atualizado_em\": \"2026-05-25T14:00:00.000000Z\"\n}"
						}
					]
				},
				{
					"name": "Registrar Técnico",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Tomás Técnico\",\n  \"login\": \"tec-tomas\",\n  \"senha\": \"senha123\",\n  \"role\": \"tecnico\"\n}" },
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					},
					"response": []
				},
				{
					"name": "Registrar — Erro: login duplicado (409)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Outro\",\n  \"login\": \"op-carla\",\n  \"senha\": \"senha123\",\n  \"role\": \"operador\"\n}" },
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					},
					"response": [
						{
							"name": "409 — Login já cadastrado",
							"originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth","register"] } },
							"status": "CONFLICT", "code": 409,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"erro\": \"Login já cadastrado\"\n}"
						}
					]
				},
				{
					"name": "Login — Operador (salva op_token)",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"const json = pm.response.json();",
								"pm.test('Status 200', () => pm.response.to.have.status(200));",
								"pm.test('Token retornado', () => pm.expect(json.token).to.be.a('string'));",
								"pm.collectionVariables.set('op_token', json.token);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"login\": \"op-carla\",\n  \"senha\": \"senha123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] },
						"description": "Faz login e armazena o token JWT em `{{op_token}}`."
					},
					"response": [
						{
							"name": "200 — Login OK",
							"originalRequest": { "method": "POST", "header": [], "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth","login"] } },
							"status": "OK", "code": 200,
							"header": [{ "key": "Content-Type", "value": "application/json" }],
							"body": "{\n  \"token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"usuario\": { \"id\": 1, \"nome\": \"Carla Operadora\", \"login\": \"op-carla\", \"role\": \"operador\", \"ativo\": 1 }\n}"
						}
					]
				},
				{
					"name": "Login — Técnico (salva tec_token)",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"pm.collectionVariables.set('tec_token', pm.response.json().token);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"login\": \"tec-tomas\",\n  \"senha\": \"senha123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					},
					"response": []
				},
				{
					"name": "Login — Erro: senha incorreta (401)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"login\": \"op-carla\",\n  \"senha\": \"errada\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					},
					"response": []
				},
				{
					"name": "GET /auth/me — Operador",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{op_token}}" }],
						"url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
					},
					"response": []
				},
				{
					"name": "GET /auth/me — Sem token (401)",
					"request": {
						"method": "GET",
						"header": [],
						"url": { "raw": "{{base_url}}/auth/me", "host": ["{{base_url}}"], "path": ["auth", "me"] }
					},
					"response": []
				}
			]
		},
		{
			"name": "Ordens de Serviço",
			"description": "Todas as rotas exigem header `Authorization: Bearer <token>`.\n\n* POST /os — apenas operadores\n* PATCH /os/<id>/(aceitar|recusar|iniciar|concluir) — apenas técnicos",
			"item": [
				{
					"name": "Criar OS — Operador",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"const json = pm.response.json();",
								"if (json.id) pm.collectionVariables.set('os_id', json.id);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{op_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Vazamento na válvula V-102\",\n  \"descricao\": \"Vazamento de óleo identificado na base da válvula V-102.\",\n  \"setor\": \"Caldeiras\",\n  \"equipamento\": \"Válvula V-102\",\n  \"prioridade\": \"alta\"\n}" },
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] },
						"description": "O `operador_id` é derivado do token JWT (não vai no body). Status inicial: `aberta`. Publica evento `os.criada` na `fila.tecnico`."
					},
					"response": []
				},
				{
					"name": "Criar OS — Erro: sem token (401)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"descricao\": \"d\",\n  \"setor\": \"s\",\n  \"equipamento\": \"e\",\n  \"prioridade\": \"alta\"\n}" },
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
				},
				{
					"name": "Criar OS — Erro: técnico não pode criar (403)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"titulo\": \"X\",\n  \"descricao\": \"d\",\n  \"setor\": \"s\",\n  \"equipamento\": \"e\",\n  \"prioridade\": \"alta\"\n}" },
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
				},
				{
					"name": "Criar OS — Erro: campo obrigatório (400)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{op_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"titulo\": \"incompleto\"\n}" },
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
				},
				{
					"name": "Listar OS — Operador",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{op_token}}" }],
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
				},
				{
					"name": "Listar OS — Técnico",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tec_token}}" }],
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
				},
				{
					"name": "Listar OS — filtro por status",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{tec_token}}" }],
						"url": {
							"raw": "{{base_url}}/os?status=aberta",
							"host": ["{{base_url}}"], "path": ["os"],
							"query": [{ "key": "status", "value": "aberta" }]
						}
					},
					"response": []
				},
				{
					"name": "Buscar OS por ID",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{op_token}}" }],
						"url": { "raw": "{{base_url}}/os/{{os_id}}", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}"] }
					},
					"response": []
				},
				{
					"name": "Buscar OS — 404",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{op_token}}" }],
						"url": { "raw": "{{base_url}}/os/9999", "host": ["{{base_url}}"], "path": ["os", "9999"] }
					},
					"response": []
				},
				{
					"name": "Aceitar OS — Técnico",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/aceitar", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "aceitar"] },
						"description": "`tecnico_id` é derivado do token. Publica evento `os.aceita` na `fila.operador`."
					},
					"response": []
				},
				{
					"name": "Recusar OS — Técnico",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/recusar", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "recusar"] }
					},
					"response": []
				},
				{
					"name": "Iniciar OS — Técnico",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/iniciar", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "iniciar"] }
					},
					"response": []
				},
				{
					"name": "Concluir OS — Técnico (com laudo)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"laudo\": \"Substituída gaxeta desgastada. Vazamento eliminado.\"\n}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/concluir", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "concluir"] }
					},
					"response": []
				},
				{
					"name": "Aceitar OS — Erro: operador não pode (403)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{op_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/aceitar", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "aceitar"] }
					},
					"response": []
				},
				{
					"name": "Transição inválida (409)",
					"request": {
						"method": "PATCH",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/iniciar", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "iniciar"] },
						"description": "Tentar iniciar uma OS já concluída → 409."
					},
					"response": []
				}
			]
		},
		{
			"name": "Materiais",
			"item": [
				{
					"name": "Registrar material — Técnico",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Gaxeta 3/4\\\"\",\n  \"quantidade\": 2\n}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/materiais", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "materiais"] }
					},
					"response": []
				},
				{
					"name": "Listar materiais",
					"request": {
						"method": "GET",
						"header": [{ "key": "Authorization", "value": "Bearer {{op_token}}" }],
						"url": { "raw": "{{base_url}}/os/{{os_id}}/materiais", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "materiais"] }
					},
					"response": []
				},
				{
					"name": "Registrar material — Erro: quantidade zero (400)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{tec_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"x\",\n  \"quantidade\": 0\n}" },
						"url": { "raw": "{{base_url}}/os/{{os_id}}/materiais", "host": ["{{base_url}}"], "path": ["os", "{{os_id}}", "materiais"] }
					},
					"response": []
				}
			]
		},
		{
			"name": "Fluxo Completo Sprint 2",
			"description": "Executar em sequência (Runner do Postman) para demonstrar:\n\n1-2. Cadastro de operador e técnico\n3-4. Login (popula op_token e tec_token automaticamente)\n5. Operador cria OS → publica `os.criada` em `fila.tecnico`\n6. Técnico aceita → publica `os.aceita` em `fila.operador`\n7. Técnico inicia → publica `os.em_andamento`\n8. Técnico registra material\n9. Técnico conclui com laudo → publica `os.concluida`\n10. Verifica estado final\n\nCom o worker rodando (`python backend/worker.py`) os 4 eventos aparecem no console e na tabela `evento_log`.",
			"item": [
				{
					"name": "1. Registrar Operador (idempotente)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Demo Operador\",\n  \"login\": \"demo-op\",\n  \"senha\": \"senha123\",\n  \"role\": \"operador\"\n}" },
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					},
					"response": []
				},
				{
					"name": "2. Registrar Técnico (idempotente)",
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"nome\": \"Demo Técnico\",\n  \"login\": \"demo-tec\",\n  \"senha\": \"senha123\",\n  \"role\": \"tecnico\"\n}" },
						"url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
					},
					"response": []
				},
				{
					"name": "3. Login Operador",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"pm.collectionVariables.set('op_token', pm.response.json().token);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"login\": \"demo-op\",\n  \"senha\": \"senha123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					},
					"response": []
				},
				{
					"name": "4. Login Técnico",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"pm.collectionVariables.set('tec_token', pm.response.json().token);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [{ "key": "Content-Type", "value": "application/json" }],
						"body": { "mode": "raw", "raw": "{\n  \"login\": \"demo-tec\",\n  \"senha\": \"senha123\"\n}" },
						"url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
					},
					"response": []
				},
				{
					"name": "5. Criar OS (Operador) — publica os.criada",
					"event": [
						{
							"listen": "test",
							"script": { "type": "text/javascript", "exec": [
								"pm.collectionVariables.set('os_id', pm.response.json().id);"
							]}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" },
							{ "key": "Authorization", "value": "Bearer {{op_token}}" }
						],
						"body": { "mode": "raw", "raw": "{\n  \"titulo\": \"Sensor TT-205 fora de faixa\",\n  \"descricao\": \"Sensor de temperatura reportando 450°C em processo de 180°C.\",\n  \"setor\": \"Reatores\",\n  \"equipamento\": \"Sensor TT-205\",\n  \"prioridade\": \"critica\"\n}" },
						"url": { "raw": "{{base_url}}/os", "host": ["{{base_url}}"], "path": ["os"] }
					},
					"response": []
